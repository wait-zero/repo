# WaitZero 환경변수 템플릿
# .env 파일로 복사 후 값을 채워주세요: cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=waitzero1234
MYSQL_DATABASE=waitzero

# Backend DB
DB_HOST=mysql
