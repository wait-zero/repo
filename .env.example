# WaitZero 환경변수 템플릿
# .env 파일로 복사 후 값을 채워주세요: cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=waitzero

# Backend DB
DB_HOST=mysql
DB_PORT=3306
DB_NAME=waitzero
DB_USERNAME=root
DB_PASSWORD=

# 공공데이터포털 API (https://www.data.go.kr 에서 발급)
PUBLIC_DATA_API_KEY=

# OpenAI (Spring AI)
OPENAI_API_KEY=
